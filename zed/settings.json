{
  "cli_default_open_behavior": "existing_window",
  "which_key": {
    "enabled": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "buffer_line_height": "comfortable",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-opus-4-6-latest",
    },
  },
  "autosave": "on_focus_change",
  "cursor_shape": "bar",
  "vim_mode": true,
  "ui_font_family": "SF Mono",
  "ui_font_size": 13,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "buffer_font_size": 13,
  "format_on_save": "on",
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "terminal": {
    "blinking": "terminal_controlled",
    "copy_on_select": true,
    "cursor_shape": "underline",
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv", "env", ".env"],
        "activate_script": "default",
      },
    },
    "dock": "bottom",
    "font_family": "Maple Mono NF",
    "shell": {
      "program": "/run/current-system/sw/bin/zsh",
    },
    "working_directory": "current_project_directory",
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "relative_line_numbers": "enabled",
}
